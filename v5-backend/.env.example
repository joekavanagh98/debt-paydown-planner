# Port the HTTP server listens on.
PORT=3001

# MongoDB connection string. Atlas free tier is fine for dev and the
# v8 deploy. Format: mongodb+srv://<user>:<pass>@<cluster>/<db-name>
# Never commit a real value; .env is gitignored.
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/debt-paydown-planner?retryWrites=true&w=majority

# Allowed origin for CORS. Pin to the v4 frontend's dev URL locally,
# or to the deployed Vercel URL in production.
CORS_ORIGIN=http://localhost:5173

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# node environment: development | production | test
NODE_ENV=development
