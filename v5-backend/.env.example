# Port the HTTP server listens on.
PORT=3001

# MongoDB connection string. Atlas free tier is fine for dev and the
# v8 deploy. Format: mongodb+srv://<user>:<pass>@<cluster>/<db-name>
# Never commit a real value; .env is gitignored.
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/debt-paydown-planner?retryWrites=true&w=majority

# Secret used to sign JWT access tokens. Must be at least 32 chars.
# Generate with: openssl rand -hex 64
# Never reuse the dev secret in production. Rotate via your host's
# secret manager rather than committing changes.
JWT_SECRET=replace-with-output-of-openssl-rand-hex-64

# JWT access token lifetime. ms-style duration (15m, 1h, 2d). Short
# by design: there is no refresh-token flow in v7, so a stolen token
# remains valid for the full duration.
JWT_EXPIRES_IN=15m

# Anthropic API key for the v8 debt-extraction endpoint. Required.
# Get one at https://console.anthropic.com. Use a project key with
# spend limits in production. Never commit a real value.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Allowed origin for CORS. Pin to the v4 frontend's dev URL locally,
# or to the deployed Vercel URL in production.
CORS_ORIGIN=http://localhost:5173

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# node environment: development | production | test
NODE_ENV=development
