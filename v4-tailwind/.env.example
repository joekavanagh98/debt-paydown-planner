# Base URL of the backend API. Vite only exposes env vars prefixed
# with VITE_ to client code. The dev value points at the v5-backend
# running on its default port; production overrides this with the
# Render deploy URL when v8 phase 2 lands.
#
# Copy this file to .env.local for development. .env.local is
# gitignored so per-developer overrides never commit.
VITE_API_URL=http://localhost:3001
